# ── Variáveis de ambiente do servidor (NÃO usam prefixo VITE_, então nunca vão
#    para o navegador). Defina-as na Vercel em Settings → Environment Variables.
#    Para rodar localmente com `vercel dev`, copie este arquivo para .env.local.

# Senha do painel de administração (/admin).
ADMIN_PASSWORD=troque-esta-senha

# Segredo usado para assinar o cookie de sessão. Gere um valor longo e aleatório.
# Ex. (Node): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-aleatorio-longo

# Armazenamento (Upstash Redis). A integração da Vercel injeta estas variáveis
# automaticamente ao criar o banco em Storage → Upstash. Localmente, cole os
# valores do painel da Upstash/Vercel.
KV_REST_API_URL=
KV_REST_API_TOKEN=
