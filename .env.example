# ── Variáveis de ambiente do servidor (NÃO usam prefixo VITE_, então nunca vão
#    para o navegador). Defina-as na Netlify em Site settings → Environment variables.
#    Para rodar localmente com `netlify dev`, copie este arquivo para .env e preencha.

# Senha do painel de administração (/admin).
ADMIN_PASSWORD=troque-esta-senha

# Segredo usado para assinar o cookie de sessão. Gere um valor longo e aleatório.
# Ex. (Node): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-aleatorio-longo

# Armazenamento (Upstash Redis). Crie um banco grátis em https://upstash.com,
# abra o database → aba "REST API" → copie a URL e o token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
